{
    "description": "Schema for a question object within a worksheet.",
    "type": "object",
    "properties": {
        "worksheet_id": {
            "type": "integer"
        },
        "question_id": {
            "type": "integer"
        },
        "index": {
            "type": "integer"
        },
        "question_text": {
            "type": "string"
        },
        "skill_code": {
            "type": "string"
        },
        "options": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "correct_option": {
            "type": "string",
            "description": "The correct option for the question. Should be one of 'A', 'B', 'C', or 'D'."
        }
    }
}